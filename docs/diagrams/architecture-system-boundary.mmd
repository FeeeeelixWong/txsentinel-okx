flowchart LR
  A["Autonomous agent"] -->|"proposed action + policy"| F["Free /api/preflight"]
  F --> V["Validate + basic readiness screen"]
  V --> Q["READY / REVIEW / BLOCKED<br/>No receipt or detailed evidence"]
  A -->|"valid formal request"| X["Paid /api/check-paid"]
  X --> P["Prepayment validation + evaluation"]
  P -->|"invalid: 422, no payment"| A
  P -->|"valid: 402 PAYMENT-REQUIRED"| W["OKX Agentic Wallet"]
  W -->|"PAYMENT-SIGNATURE"| X
  X <-->|"verify + settle"| O["OKX x402 facilitator"]
  X --> R["ALLOW / HOLD / DENY<br/>Evidence + stable hashes"]
  R -->|"optional wallet attestation"| C["X Layer Policy Anchor"]
